{
  "requiredTopLevelKeys": [
    "version",
    "scope",
    "sinks",
    "indexNames",
    "ui"
  ],
  "sinks": {
    "requiredKeys": [ "files", "database" ],
    "files": {
      "allowedKeys": [ "enabled", "path", "formats", "limits" ],
      "allowedFormats": [ "jsonl", "bulkNdjson" ],
      "limits": {
        "allowedKeys": [ "totalEnabled", "totalGb", "diskUsedPercentEnabled", "maxDiskUsedPercent" ]
      }
    },
    "database": {
      "allowedKeys": [ "enabled", "type", "openSearch", "openSearchAmazon", "elasticsearch" ],
      "allowedTypes": [ "openSearch", "openSearchAmazon", "elasticsearch" ],
      "openSearch": {
      "allowedKeys": [ "url", "tlsMode", "auth", "pinnedTlsCertificate" ],
      "auth": {
        "allowedKeys": [ "type", "username", "apiKeyId", "certPath", "certKeyPath" ],
        "allowedTypes": [ "API key", "Bearer token", "Certificate", "Basic", "None" ],
        "allowedFieldsByType": {
          "API key": [ "apiKeyId" ],
          "Bearer token": [],
          "Certificate": [ "certPath", "certKeyPath" ],
          "Basic": [ "username" ],
          "None": []
        }
      },
      "pinnedTlsCertificate": {
        "allowedKeys": [ "sourcePath", "fingerprintSha256", "encodedBase64" ]
      }
      },
      "openSearchAmazon": {
        "allowedKeys": [ "url", "region", "profile", "tlsMode", "auth", "pinnedTlsCertificate" ],
        "auth": {
          "allowedKeys": [ "type", "username" ],
          "allowedTypes": [ "IAM (sigV4)", "Basic", "None" ]
        },
        "pinnedTlsCertificate": {
          "allowedKeys": [ "sourcePath", "fingerprintSha256", "encodedBase64" ]
        }
      },
      "elasticsearch": {
        "allowedKeys": [ "url", "tlsMode", "auth", "pinnedTlsCertificate" ],
        "auth": {
          "allowedKeys": [ "type", "username", "certPath", "certKeyPath" ],
          "allowedTypes": [ "API key", "Bearer token", "Certificate", "Basic", "None" ]
        },
        "pinnedTlsCertificate": {
          "allowedKeys": [ "sourcePath", "fingerprintSha256", "encodedBase64" ]
        }
      }
    }
  }
}
